<UserControl x:Class="LaserCollisionIn3DObjects.Wpf.Views.GraphicMasterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:conv="clr-namespace:LaserCollisionIn3DObjects.Wpf.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:FlexibleNumericConverter x:Key="FlexibleNumericConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="12" BorderBrush="#D8D8D8" BorderThickness="0,0,1,0" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Graphic Master" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <GroupBox Header="Graph Type" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <ComboBox ItemsSource="{Binding GraphicMasterWorkspace.GraphTypes}"
                                      SelectedItem="{Binding GraphicMasterWorkspace.SelectedGraphType}"
                                      DisplayMemberPath="DisplayName"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Chart" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Chart Name"/>
                            <TextBox Text="{Binding GraphicMasterWorkspace.ChartName, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Graph Sources" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" Foreground="#555" Margin="0,0,0,6"
                                       Text="Select cylindrical sources and/or projection results from all scenes."/>
                            <ListBox ItemsSource="{Binding GraphicMasterWorkspace.Sources}" Height="280" BorderThickness="1" BorderBrush="#D1D5DB">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayName}" Margin="2"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Parameters" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Angle Bin Size (deg)"/>
                            <TextBox Text="{Binding GraphicMasterWorkspace.BinSizeDeg, Converter={StaticResource FlexibleNumericConverter}, UpdateSourceTrigger=LostFocus}"/>
                        </StackPanel>
                    </GroupBox>

                    <Button Content="Generate Chart"
                            Command="{Binding GraphicMasterWorkspace.GenerateChartCommand}"
                            Height="32"/>

                    <GroupBox Header="Stored Charts (runtime only)" Margin="0,8,0,8" Padding="8">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="Delete Selected"
                                        Command="{Binding GraphicMasterWorkspace.DeleteStoredChartCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="Save Current as PNG"
                                        Command="{Binding GraphicMasterWorkspace.SaveChartAsPngCommand}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding GraphicMasterWorkspace.StoredCharts}"
                                     SelectedItem="{Binding GraphicMasterWorkspace.SelectedStoredChart}"
                                     Height="180"
                                     DisplayMemberPath="DisplayName"
                                     BorderThickness="1"
                                     BorderBrush="#D1D5DB"/>
                        </DockPanel>
                    </GroupBox>

                    <TextBlock Margin="0,8,0,0"
                               Foreground="#374151"
                               TextWrapping="Wrap"
                               Text="{Binding GraphicMasterWorkspace.StatusMessage}"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" Padding="12" Background="White">
            <oxy:PlotView x:Name="ChartPlotView"
                          Model="{Binding GraphicMasterWorkspace.PlotModel}"
                          SizeChanged="OnChartPlotViewSizeChanged" />
        </Border>
    </Grid>
</UserControl>

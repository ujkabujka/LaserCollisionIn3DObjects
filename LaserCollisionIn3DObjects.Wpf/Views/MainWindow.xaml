<Window x:Class="LaserCollisionIn3DObjects.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:h="http://helixToolkit.org/wpf"
        mc:Ignorable="d"
        Title="Laser Collision in 3D Objects"
        Width="1200"
        Height="700"
        MinWidth="900"
        MinHeight="560">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="16" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <StackPanel>
                <TextBlock Text="Scene Editor" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,12" />
                <TextBlock Text="This panel will host controls for rays, prisms, and scene parameters." TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <h:HelixViewport3D ShowCoordinateSystem="True" ShowViewCube="True">
                <h:SunLight />
            </h:HelixViewport3D>
        </Grid>
    </Grid>
</Window>

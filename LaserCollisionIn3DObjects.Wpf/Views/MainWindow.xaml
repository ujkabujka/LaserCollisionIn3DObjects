<Window x:Class="LaserCollisionIn3DObjects.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:LaserCollisionIn3DObjects.Wpf.Converters"
        xmlns:vm="clr-namespace:LaserCollisionIn3DObjects.Wpf.ViewModels"
        xmlns:v="clr-namespace:LaserCollisionIn3DObjects.Wpf.Views"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1500"
        Height="900"
        MinWidth="1200"
        MinHeight="760">
    <Window.Resources>
        <conv:FlexibleNumericConverter x:Key="FlexibleNumericConverter"/>

        <Style x:Key="NavigationButtonBaseStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavigationLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="10,0,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsNavigationCollapsed}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="Save Project" Command="{Binding SaveProjectCommand}"/>
                <MenuItem Header="Load Project" Command="{Binding LoadProjectCommand}"/>
                <Separator/>
                <MenuItem Header="Save Collision View State" Command="{Binding SaveCollisionTabCommand}"/>
                <MenuItem Header="Load Collision View State" Command="{Binding LoadCollisionTabCommand}"/>
                <MenuItem Header="Save Annotation View State" Command="{Binding SaveAnnotationTabCommand}"/>
                <MenuItem Header="Load Annotation View State" Command="{Binding LoadAnnotationTabCommand}"/>
                <MenuItem Header="Save Projection View State" Command="{Binding SaveProjectionTabCommand}"/>
                <MenuItem Header="Load Projection View State" Command="{Binding LoadProjectionTabCommand}"/>
                <Separator/>
                <MenuItem Header="E_xit" Command="ApplicationCommands.Close" CommandTarget="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </MenuItem>
            <MenuItem Header="_View"/>
            <MenuItem Header="_Tools"/>
            <MenuItem Header="_Help"/>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#F8FAFC" BorderBrush="#E5E7EB" BorderThickness="0,0,1,0">
                <Grid Width="{Binding NavigationRailWidth}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ToggleButton Grid.Row="0"
                                  Margin="8"
                                  Padding="8"
                                  FontSize="18"
                                  Content="☰"
                                  IsChecked="{Binding IsNavigationCollapsed}"
                                  ToolTip="Collapse navigation"/>

                    <StackPanel Grid.Row="1" Margin="8,4,8,8">
                        <Button Command="{Binding ShowCollisionWorkspaceCommand}"
                                Margin="0,0,0,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavigationButtonBaseStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Static vm:WorkspaceKind.Collision}">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚙" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Collision" Style="{StaticResource NavigationLabelStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowAnnotationWorkspaceCommand}"
                                Margin="0,0,0,6">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavigationButtonBaseStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Static vm:WorkspaceKind.Annotation}">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🖼" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Annotation" Style="{StaticResource NavigationLabelStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowProjectionWorkspaceCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource NavigationButtonBaseStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Static vm:WorkspaceKind.Projection}">
                                            <Setter Property="Background" Value="#DBEAFE"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📐" FontSize="14" VerticalAlignment="Center"/>
                                <TextBlock Text="Projection" Style="{StaticResource NavigationLabelStyle}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <v:CollisionWorkspaceView x:Name="CollisionWorkspaceView" DataContext="{Binding}">
                    <v:CollisionWorkspaceView.Style>
                        <Style TargetType="v:CollisionWorkspaceView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Static vm:WorkspaceKind.Collision}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </v:CollisionWorkspaceView.Style>
                </v:CollisionWorkspaceView>

                <v:AnnotationWorkspaceView DataContext="{Binding}">
                    <v:AnnotationWorkspaceView.Style>
                        <Style TargetType="v:AnnotationWorkspaceView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Static vm:WorkspaceKind.Annotation}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </v:AnnotationWorkspaceView.Style>
                </v:AnnotationWorkspaceView>

                <v:ProjectionWorkspaceView x:Name="ProjectionWorkspaceView" DataContext="{Binding}">
                    <v:ProjectionWorkspaceView.Style>
                        <Style TargetType="v:ProjectionWorkspaceView">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedWorkspace}" Value="{x:Static vm:WorkspaceKind.Projection}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </v:ProjectionWorkspaceView.Style>
                </v:ProjectionWorkspaceView>
            </Grid>
        </Grid>
    </DockPanel>
</Window>

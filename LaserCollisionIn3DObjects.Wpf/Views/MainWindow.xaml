<Window x:Class="LaserCollisionIn3DObjects.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:h="http://helix-toolkit.org/wpf"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1500"
        Height="900"
        MinWidth="1200"
        MinHeight="760">
    <TabControl>
        <TabItem Header="Collision Workspace">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="430" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="12" BorderBrush="#D8D8D8" BorderThickness="0,0,1,0" Background="#FAFAFA">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Scene Editor" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />
                            <GroupBox Header="Prisms" Margin="0,0,0,8" Padding="8">
                                <StackPanel>
                                    <Grid Margin="0,0,0,6"><Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Grid.Column="0" Text="Name" VerticalAlignment="Center"/><TextBox Grid.Column="1" Text="{Binding NewPrismName}"/></Grid>
                                    <UniformGrid Columns="3" Margin="0,0,0,6"><StackPanel Margin="2"><TextBlock Text="Pos X"/><TextBox Text="{Binding NewPrismPosX}"/></StackPanel><StackPanel Margin="2"><TextBlock Text="Pos Y"/><TextBox Text="{Binding NewPrismPosY}"/></StackPanel><StackPanel Margin="2"><TextBlock Text="Pos Z"/><TextBox Text="{Binding NewPrismPosZ}"/></StackPanel></UniformGrid>
                                    <UniformGrid Columns="3" Margin="0,0,0,6"><StackPanel Margin="2"><TextBlock Text="Rot X"/><TextBox Text="{Binding NewPrismRotX}"/></StackPanel><StackPanel Margin="2"><TextBlock Text="Rot Y"/><TextBox Text="{Binding NewPrismRotY}"/></StackPanel><StackPanel Margin="2"><TextBlock Text="Rot Z"/><TextBox Text="{Binding NewPrismRotZ}"/></StackPanel></UniformGrid>
                                    <UniformGrid Columns="3" Margin="0,0,0,6"><StackPanel Margin="2"><TextBlock Text="Size X"/><TextBox Text="{Binding NewPrismSizeX}"/></StackPanel><StackPanel Margin="2"><TextBlock Text="Size Y"/><TextBox Text="{Binding NewPrismSizeY}"/></StackPanel><StackPanel Margin="2"><TextBlock Text="Size Z"/><TextBox Text="{Binding NewPrismSizeZ}"/></StackPanel></UniformGrid>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6"><Button Content="Add Prism" Command="{Binding AddPrismCommand}" Width="100" Margin="0,0,8,0"/><Button Content="Add Array" Command="{Binding AddPrismArrayCommand}" Width="95" Margin="0,0,8,0"/><Button Content="Remove Selected" Command="{Binding RemoveSelectedPrismCommand}" Width="120" Margin="0,0,8,0"/><Button Content="Delete All Prisms" Command="{Binding RemoveAllPrismsCommand}" Width="125"/></StackPanel>
                                    <DataGrid ItemsSource="{Binding Prisms}" SelectedItem="{Binding SelectedPrism}" AutoGenerateColumns="False" CanUserAddRows="False" Height="140">
                                        <DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/><DataGridTextColumn Header="Sx" Binding="{Binding SizeX}" Width="45"/><DataGridTextColumn Header="Sy" Binding="{Binding SizeY}" Width="45"/><DataGridTextColumn Header="Sz" Binding="{Binding SizeZ}" Width="45"/></DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Actions" Margin="0,0,0,8" Padding="8">
                                <StackPanel>
                                    <Button Content="Run Collision" Command="{Binding RunCollisionCommand}" Width="120" Height="30" Margin="0,0,8,6"/>
                                    <Button Content="Reset Demo Scene" Command="{Binding ResetDemoSceneCommand}" Width="140" Height="30" Margin="0,0,8,6"/>
                                    <TextBlock Text="{Binding LastCollisionDurationMs, StringFormat=Last Run: {0} ms}"/>
                                    <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Header="Results" Padding="8">
                                <DataGrid ItemsSource="{Binding HitResults}" AutoGenerateColumns="False" CanUserAddRows="False" Height="160">
                                    <DataGrid.Columns><DataGridTextColumn Header="Ray" Binding="{Binding RayLabel}" Width="70"/><DataGridCheckBoxColumn Header="Hit" Binding="{Binding HasHit}" Width="45"/><DataGridTextColumn Header="Distance" Binding="{Binding Distance, StringFormat=F3}" Width="85"/><DataGridTextColumn Header="Prism" Binding="{Binding PrismName}" Width="*"/></DataGrid.Columns>
                                </DataGrid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <Grid Grid.Column="1">
                    <h:HelixViewport3D x:Name="Viewport" ShowCoordinateSystem="True" ShowViewCube="True" ZoomExtentsWhenLoaded="True">
                        <h:HelixViewport3D.Camera>
                            <PerspectiveCamera Position="0,-30,30" LookDirection="0,30,-30" UpDirection="0,0,1" FieldOfView="45" />
                        </h:HelixViewport3D.Camera>
                        <h:SunLight />
                        <h:GridLinesVisual3D Width="120" Length="120" MinorDistance="5" MajorDistance="10" />
                    </h:HelixViewport3D>
                </Grid>
            </Grid>
        </TabItem>

        <TabItem Header="Annotation Verification">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Column="0" Grid.RowSpan="2" BorderBrush="#D8D8D8" BorderThickness="1" Padding="10" Background="#FAFAFA">
                    <StackPanel>
                        <TextBlock Text="VIA Annotation Workspace" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Button Content="Select Annotation Folder" Command="{Binding AnnotationWorkspace.SelectFolderCommand}" Height="30" />
                        <TextBlock Text="{Binding AnnotationWorkspace.SelectedFolderPath}" TextWrapping="Wrap" Margin="0,8,0,8" Foreground="#444" />
                        <TextBlock Text="Images" FontWeight="SemiBold" />
                        <ListBox ItemsSource="{Binding AnnotationWorkspace.Images}" SelectedItem="{Binding AnnotationWorkspace.SelectedImage}" Height="220" DisplayMemberPath="DisplayName" Margin="0,4,0,8" />
                        <TextBlock Text="Selected Image Details" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding AnnotationWorkspace.SelectedImage.PanelCornersText, TargetNullValue=N/A}" TextWrapping="Wrap" Margin="0,4,0,8" />
                        <DataGrid ItemsSource="{Binding AnnotationWorkspace.SelectedImage.Holes}" AutoGenerateColumns="False" CanUserAddRows="False" Height="260">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="35"/>
                                <DataGridTextColumn Header="Shape" Binding="{Binding ShapeType}" Width="65"/>
                                <DataGridTextColumn Header="Orig Center" Binding="{Binding OriginalCenter}" Width="120"/>
                                <DataGridTextColumn Header="Warp Center" Binding="{Binding WarpedCenter}" Width="120"/>
                                <DataGridTextColumn Header="Area(px²)" Binding="{Binding PixelArea}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="{Binding AnnotationWorkspace.StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#1A5276" />
                    </StackPanel>
                </Border>

                <GroupBox Grid.Column="1" Grid.Row="0" Header="Original Image + Panel Fit" Margin="10,0,0,10">
                    <Grid Background="#222">
                        <Image Source="{Binding AnnotationWorkspace.SelectedImage.OriginalImage}" Stretch="Uniform"/>
                        <Image Source="{Binding AnnotationWorkspace.SelectedImage.OriginalOverlay}" Stretch="Uniform"/>
                    </Grid>
                </GroupBox>

                <GroupBox Grid.Column="1" Grid.Row="1" Header="Rectified Panel + Warped Hole Centers" Margin="10,0,0,0">
                    <Grid Background="#222">
                        <Image Source="{Binding AnnotationWorkspace.SelectedImage.WarpedImage}" Stretch="Uniform"/>
                        <Image Source="{Binding AnnotationWorkspace.SelectedImage.WarpedOverlay}" Stretch="Uniform"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </TabItem>
    </TabControl>
</Window>

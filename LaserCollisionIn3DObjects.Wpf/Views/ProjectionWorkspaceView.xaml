<UserControl x:Class="LaserCollisionIn3DObjects.Wpf.Views.ProjectionWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="http://helix-toolkit.org/wpf"
             xmlns:conv="clr-namespace:LaserCollisionIn3DObjects.Wpf.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:FlexibleNumericConverter x:Key="FlexibleNumericConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="12" BorderBrush="#D8D8D8" BorderThickness="0,0,1,0" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Projection Workspace" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,10" />

                    <GroupBox Header="Scene Selection" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <TextBlock Margin="0,0,0,6" Foreground="#555" TextWrapping="Wrap"
                                       Text="Only scenes that contain 3D hole points are listed here." />
                            <ListBox ItemsSource="{Binding ProjectionWorkspace.AvailableScenes}"
                                     SelectedItem="{Binding ProjectionWorkspace.SelectedScene}"
                                     DisplayMemberPath="Name"
                                     Height="140" />
                            <Button Content="Import Hit Points CSV"
                                    Command="{Binding ProjectionWorkspace.ImportHitPointsCsvCommand}"
                                    Height="28"
                                    Margin="0,6,0,0"/>
                            <Button Content="Delete Selected Scene"
                                    Command="{Binding ProjectionWorkspace.DeleteSelectedProjectionSceneCommand}"
                                    Height="28"
                                    Margin="0,6,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Methodology" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <ComboBox ItemsSource="{Binding ProjectionWorkspace.ProjectionMethods}"
                                      SelectedItem="{Binding ProjectionWorkspace.SelectedMethod}"
                                      DisplayMemberPath="DisplayName"
                                      Margin="0,0,0,6" />
                            <TextBlock Text="{Binding ProjectionWorkspace.SelectedMethod.Description}"
                                       Foreground="#555"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Projection Result" Margin="0,0,0,8" Padding="8">
                        <StackPanel>
                            <TextBlock Text="Result Name"/>
                            <TextBox Text="{Binding ProjectionWorkspace.NewResultName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6"/>
                            <TextBlock Text="Saved Results"/>
                            <ListBox ItemsSource="{Binding ProjectionWorkspace.SavedResults}"
                                     SelectedItem="{Binding ProjectionWorkspace.SelectedResult}"
                                     DisplayMemberPath="DisplayName"
                                     Height="90" />
                            <Button Content="Delete Selected Result"
                                    Command="{Binding ProjectionWorkspace.DeleteSelectedResultCommand}"
                                    Height="28"
                                    Margin="0,6,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Point Source Parameters" Margin="0,0,0,8" Padding="8"
                              Visibility="{Binding ProjectionWorkspace.IsPointSourceMethodSelected, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Point Source Origin"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Point Source X"/><TextBox Text="{Binding ProjectionWorkspace.PointSourceX, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Point Source Y"/><TextBox Text="{Binding ProjectionWorkspace.PointSourceY, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Point Source Z"/><TextBox Text="{Binding ProjectionWorkspace.PointSourceZ, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                            <TextBlock Text="Laser Beam Frame Origin"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Beam Origin X"/><TextBox Text="{Binding ProjectionWorkspace.BeamOriginX, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Beam Origin Y"/><TextBox Text="{Binding ProjectionWorkspace.BeamOriginY, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Beam Origin Z"/><TextBox Text="{Binding ProjectionWorkspace.BeamOriginZ, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                            <TextBlock Text="Laser Beam Frame X Direction"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Xx"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameXx, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Xy"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameXy, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Xz"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameXz, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                            <TextBlock Text="Laser Beam Frame Y Direction"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Yx"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameYx, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Yy"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameYy, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Yz"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameYz, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Cylindrical Source Parameters" Margin="0,0,0,8" Padding="8"
                              Visibility="{Binding ProjectionWorkspace.IsAnyCylindricalMethodSelected, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Source Frame Origin"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Origin X"/><TextBox Text="{Binding ProjectionWorkspace.BeamOriginX, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Origin Y"/><TextBox Text="{Binding ProjectionWorkspace.BeamOriginY, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Origin Z"/><TextBox Text="{Binding ProjectionWorkspace.BeamOriginZ, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                            <TextBlock Text="Source Frame X Direction"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Xx"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameXx, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Xy"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameXy, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Xz"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameXz, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                            <TextBlock Text="Source Frame Y Direction"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Yx"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameYx, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Yy"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameYy, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Yz"/><TextBox Text="{Binding ProjectionWorkspace.SourceFrameYz, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="2" Margin="0,0,0,6">
                                <StackPanel Margin="2"><TextBlock Text="Radius"/><TextBox Text="{Binding ProjectionWorkspace.CylindricalRadius, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                <StackPanel Margin="2"><TextBlock Text="Length"/><TextBox Text="{Binding ProjectionWorkspace.CylindricalLength, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                            </UniformGrid>
                            <StackPanel Visibility="{Binding ProjectionWorkspace.IsSelfCalibratingCylindricalMethodSelected, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Local Tilt Point"/>
                                <UniformGrid Columns="3" Margin="0,0,0,6">
                                    <StackPanel Margin="2"><TextBlock Text="Tilt X"/><TextBox Text="{Binding ProjectionWorkspace.TiltPointX, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                    <StackPanel Margin="2"><TextBlock Text="Tilt Y"/><TextBox Text="{Binding ProjectionWorkspace.TiltPointY, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                    <StackPanel Margin="2"><TextBlock Text="Tilt Z"/><TextBox Text="{Binding ProjectionWorkspace.TiltPointZ, UpdateSourceTrigger=LostFocus, Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <StackPanel Margin="0,0,0,8"
                                Visibility="{Binding ProjectionWorkspace.IsProgressVisible, Converter={StaticResource BoolToVisibility}}">
                        <ProgressBar Minimum="0" Maximum="100" Height="18" Value="{Binding ProjectionWorkspace.ProjectionProgressPercent, Mode=OneWay}" />
                        <TextBlock Text="{Binding ProjectionWorkspace.ProjectionProgressMessage}" Foreground="#666" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Button Content="Run Projection"
                            Command="{Binding ProjectionWorkspace.RunProjectionCommand}"
                            Width="130"
                            Height="30"
                            Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding ProjectionWorkspace.StatusMessage}" TextWrapping="Wrap" Foreground="#444" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Grid Grid.Column="1">
            <h:HelixViewport3D x:Name="ProjectionViewport" ShowCoordinateSystem="True" ShowViewCube="True" ZoomExtentsWhenLoaded="True">
                <h:HelixViewport3D.Camera>
                    <PerspectiveCamera Position="0,-30,30" LookDirection="0,30,-30" UpDirection="0,0,1" FieldOfView="45" />
                </h:HelixViewport3D.Camera>
                <h:SunLight />
                <h:GridLinesVisual3D Width="120" Length="120" MinorDistance="5" MajorDistance="10" />
            </h:HelixViewport3D>
        </Grid>
    </Grid>
</UserControl>

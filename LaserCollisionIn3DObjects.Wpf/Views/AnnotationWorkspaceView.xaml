<UserControl x:Class="LaserCollisionIn3DObjects.Wpf.Views.AnnotationWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avm="clr-namespace:LaserCollisionIn3DObjects.Wpf.Features.Annotations.ViewModels"
             xmlns:conv="clr-namespace:LaserCollisionIn3DObjects.Wpf.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:FlexibleNumericConverter x:Key="FlexibleNumericConverter"/>
    </UserControl.Resources>
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"  BorderBrush="#D8D8D8" BorderThickness="1" Padding="10" Background="#FAFAFA">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="VIA Annotation Workspace" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Button Content="Select Annotation Folder" Command="{Binding AnnotationWorkspace.SelectFolderCommand}" Height="30" />
                    <Button Content="Restore / Relink Missing Folder" Command="{Binding AnnotationWorkspace.RelinkMissingFolderCommand}" Height="26" Margin="0,6,0,0"/>
                    <TextBlock Text="{Binding AnnotationWorkspace.SelectedFolderPath}" TextWrapping="Wrap" Margin="0,8,0,8" Foreground="#444" />
                    <TextBlock Text="{Binding AnnotationWorkspace.StatusMessage}" TextWrapping="Wrap" Margin="0,0,0,8" Foreground="#1A5276" />
                    <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,8" Background="#F7F9FB">
                        <TextBlock Text="{Binding AnnotationWorkspace.SelectedImageSummary}" TextWrapping="Wrap" />
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Button Content="◀ Prev" Command="{Binding AnnotationWorkspace.SelectPreviousImageCommand}" Width="85" Margin="0,0,6,0"/>
                        <Button Content="Next ▶" Command="{Binding AnnotationWorkspace.SelectNextImageCommand}" Width="85" Margin="0,0,6,0"/>
                        <TextBlock VerticalAlignment="Center" Text="{Binding AnnotationWorkspace.SelectedImageIndex, StringFormat=Index: {0}}" />
                    </StackPanel>

                    <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,8" Background="#F7F9FB">
                        <StackPanel>
                            <TextBlock Text="Panel Dimensions (mm)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2">
                                    <TextBlock Text="Global Width"/>
                                    <TextBox Text="{Binding AnnotationWorkspace.GlobalPanelWidthMm, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource FlexibleNumericConverter}}"/>
                                </StackPanel>
                                <StackPanel Margin="2">
                                    <TextBlock Text="Global Height"/>
                                    <TextBox Text="{Binding AnnotationWorkspace.GlobalPanelHeightMm, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource FlexibleNumericConverter}}"/>
                                </StackPanel>
                                <StackPanel Margin="2">
                                    <TextBlock Text="Global Thickness"/>
                                    <TextBox Text="{Binding AnnotationWorkspace.GlobalPanelThicknessMm, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource FlexibleNumericConverter}}"/>
                                </StackPanel>
                            </UniformGrid>
                            <Button Content="Apply To All Images"
                                    Command="{Binding AnnotationWorkspace.ApplyGlobalPanelDimensionsCommand}"
                                    Height="26"
                                    Margin="0,0,0,6"/>
                            <UniformGrid Columns="3" Margin="0,0,0,6">
                                <StackPanel Margin="2">
                                    <TextBlock Text="Selected Width"/>
                                    <TextBox Text="{Binding AnnotationWorkspace.SelectedImage.PanelWidthMm, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/>
                                </StackPanel>
                                <StackPanel Margin="2">
                                    <TextBlock Text="Selected Height"/>
                                    <TextBox Text="{Binding AnnotationWorkspace.SelectedImage.PanelHeightMm, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/>
                                </StackPanel>
                                <StackPanel Margin="2">
                                    <TextBlock Text="Selected Thickness"/>
                                    <TextBox Text="{Binding AnnotationWorkspace.SelectedImage.PanelThicknessMm, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/>
                                </StackPanel>
                            </UniformGrid>
                            <Button Content="Generate Scene"
                                    Command="{Binding AnnotationWorkspace.GenerateSceneCommand}"
                                    Height="28"/>
                        </StackPanel>
                    </Border>

                    <GroupBox Header="Corner Measurements" Margin="0,0,0,8" Padding="6">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="300">
                            <ItemsControl ItemsSource="{Binding AnnotationWorkspace.SelectedImage.CornerMeasurements, TargetNullValue={x:Null}}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#D0D7DE" BorderThickness="1" CornerRadius="4" Padding="6" Margin="0,0,0,6" Background="#FFFFFF">
                                            <StackPanel>
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="Input Mode" Width="75" VerticalAlignment="Center"/>
                                                    <ComboBox Width="220"
                                                              ItemsSource="{Binding DataContext.AnnotationWorkspace.CornerMeasurementModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                              SelectedItem="{Binding SelectedMode, UpdateSourceTrigger=PropertyChanged}"/>
                                                </StackPanel>

                                                <StackPanel Margin="0,0,0,6">
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static avm:CornerMeasurementMode.ManualMeasurement}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="Manual Measurement" FontWeight="SemiBold" Foreground="#2E4053"/>
                                                    <UniformGrid Columns="3">
                                                        <StackPanel Margin="2"><TextBlock Text="Azimuth (deg)"/><TextBox Text="{Binding ManualAzimuthDeg, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                                        <StackPanel Margin="2"><TextBlock Text="Elevation (deg)"/><TextBox Text="{Binding ManualElevationDeg, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                                        <StackPanel Margin="2"><TextBlock Text="Distance (m)"/><TextBox Text="{Binding ManualDistanceMeters, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                                    </UniformGrid>
                                                </StackPanel>

                                                <StackPanel>
                                                    <StackPanel.Style>
                                                        <Style TargetType="StackPanel">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding SelectedMode}" Value="{x:Static avm:CornerMeasurementMode.DirectCoordinateTheodolite}">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </StackPanel.Style>
                                                    <TextBlock Text="Direct Coordinate (Theodolite)" FontWeight="SemiBold" Foreground="#2E4053"/>
                                                    <UniformGrid Columns="3">
                                                        <StackPanel Margin="2"><TextBlock Text="X (m)"/><TextBox Text="{Binding DirectX, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                                        <StackPanel Margin="2"><TextBlock Text="Y (m)"/><TextBox Text="{Binding DirectY, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                                        <StackPanel Margin="2"><TextBlock Text="Z (m)"/><TextBox Text="{Binding DirectZ, UpdateSourceTrigger=PropertyChanged, TargetNullValue='', Converter={StaticResource FlexibleNumericConverter}}"/></StackPanel>
                                                    </UniformGrid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </GroupBox>

                    <TextBlock Text="Images" FontWeight="SemiBold" />
                    <ListBox ItemsSource="{Binding AnnotationWorkspace.Images}" SelectedItem="{Binding AnnotationWorkspace.SelectedImage}" Height="220" DisplayMemberPath="DisplayName" Margin="0,4,0,8" />
                    <TextBlock Text="Fitted Panel Corners" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding AnnotationWorkspace.SelectedImage.PanelCornersText, TargetNullValue=N/A}" TextWrapping="Wrap" Margin="0,4,0,8" />
                    <DataGrid ItemsSource="{Binding AnnotationWorkspace.SelectedImage.Holes}" AutoGenerateColumns="False" CanUserAddRows="False" Height="250" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="#" Binding="{Binding Index}" Width="35"/>
                            <DataGridTextColumn Header="Source Shape" Binding="{Binding ShapeType}" Width="90"/>
                            <DataGridTextColumn Header="Original Center" Binding="{Binding OriginalCenter}" Width="110"/>
                            <DataGridTextColumn Header="Warped Center" Binding="{Binding WarpedCenter}" Width="110"/>
                            <DataGridTextColumn Header="Warped Center (mm)" Binding="{Binding WarpedCenterMm}" Width="120"/>
                            <DataGridTextColumn Header="Area (px²)" Binding="{Binding PixelArea}" Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <TextBlock Text="{Binding AnnotationWorkspace.StatusMessage}" TextWrapping="Wrap" Margin="0,8,0,0" Foreground="#1A5276" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GroupBox Grid.Column="1" Header="Original Image + Overlay" Margin="10,0,0,10">
            <ScrollViewer x:Name="OriginalScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="OnAnnotationViewerPreviewMouseWheel"
                          SizeChanged="OnOriginalScrollViewerSizeChanged">
                <Grid Background="#222" MinHeight="280" MinWidth="450" ClipToBounds="True">
                    <Canvas x:Name="OriginalCanvas" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Canvas.RenderTransform>
                            <ScaleTransform x:Name="OriginalScaleTransform"/>
                        </Canvas.RenderTransform>
                        <Image x:Name="OriginalBaseImage"
                               Source="{Binding AnnotationWorkspace.SelectedImage.OriginalImage}"
                               Stretch="None"
                               SizeChanged="OnOriginalBaseImageSizeChanged"/>
                        <Image Source="{Binding AnnotationWorkspace.SelectedImage.OriginalOverlay}"
                               Stretch="None"
                               IsHitTestVisible="False"
                               Panel.ZIndex="1"/>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </GroupBox>

        <GroupBox Grid.Column="2" Header="Rectified Panel + Warped Hole Centers" Margin="10,0,0,0">
            <ScrollViewer x:Name="WarpedScrollViewer"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="OnAnnotationViewerPreviewMouseWheel"
                          SizeChanged="OnWarpedScrollViewerSizeChanged">
                <Grid Background="#222" MinHeight="280" MinWidth="450" ClipToBounds="True">
                    <Canvas x:Name="WarpedCanvas" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Canvas.RenderTransform>
                            <ScaleTransform x:Name="WarpedScaleTransform"/>
                        </Canvas.RenderTransform>
                        <Image x:Name="WarpedBaseImage"
                               Source="{Binding AnnotationWorkspace.SelectedImage.WarpedImage}"
                               Stretch="None"
                               SizeChanged="OnWarpedBaseImageSizeChanged"/>
                        <Image Source="{Binding AnnotationWorkspace.SelectedImage.WarpedOverlay}"
                               Stretch="None"
                               IsHitTestVisible="False"
                               Panel.ZIndex="1"/>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </GroupBox>
    </Grid>
</UserControl>

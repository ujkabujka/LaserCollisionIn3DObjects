<Window x:Class="BaseFramework.WpfHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:navigation="clr-namespace:BaseFramework.Wpf.Controls.Navigation;assembly=BaseFramework.Wpf"
        mc:Ignorable="d"
        Title="BaseFramework Example Gallery"
        Height="900"
        Width="1400"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        ResizeMode="CanResize"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="16">
        <navigation:NavigationHostControl x:Name="NavigationHost" />
    </Grid>
</Window>

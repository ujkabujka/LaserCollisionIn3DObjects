<UserControl x:Class="BaseFramework.Wpf.Controls.Navigation.NavigationHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nav="clr-namespace:BaseFramework.Wpf.Controls.Navigation"
             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="NavColumn" Width="220" MinWidth="72" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#17171C"
                CornerRadius="8"
                Margin="0,0,12,0"
                Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <Button Width="28"
                            Height="28"
                            HorizontalAlignment="Left"
                            Click="OnToggleCollapsed"
                            ToolTip="Navigation'i daralt/genislet"
                            Content="☰" />
                    <TextBlock x:Name="NavigationTitle"
                               Text="Gezinme"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center" />
                </DockPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ListBox x:Name="NavList"
                             ItemsSource="{Binding Pages, RelativeSource={RelativeSource AncestorType=UserControl}}"
                             SelectedItem="{Binding SelectedPage, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="{x:Type nav:NavigationPage}">
                                <Border CornerRadius="6"
                                        Margin="0,4,0,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1F1F26" />
                                            <Setter Property="BorderBrush" Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#2F2F36" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid Margin="10,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition x:Name="IconColumn" Width="18" />
                                            <ColumnDefinition x:Name="TitleColumn" Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="PageIcon"
                                                   Grid.Column="0"
                                                   Text="{Binding Icon}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontSize="14"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                        <TextBlock x:Name="PageTitle"
                                                   Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   Foreground="{StaticResource TextBrush}"
                                                   FontWeight="SemiBold"
                                                   Margin="10,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsCollapsed, RelativeSource={RelativeSource AncestorType=nav:NavigationHostControl}}" Value="True">
                                        <Setter TargetName="PageTitle" Property="Visibility" Value="Collapsed" />
                                        <Setter TargetName="TitleColumn" Property="Width" Value="0" />
                                        <Setter TargetName="IconColumn" Property="Width" Value="*" />
                                        <Setter TargetName="PageIcon" Property="HorizontalAlignment" Value="Center" />
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Margin="2,0"
                      Background="{StaticResource SurfaceBrush}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ShowsPreview="True" />

        <Border Grid.Column="2"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8"
                Padding="16">
            <ContentPresenter x:Name="ContentHost"
                              Content="{Binding SelectedPage.Content, RelativeSource={RelativeSource AncestorType=UserControl}}" />
        </Border>
    </Grid>
</UserControl>

